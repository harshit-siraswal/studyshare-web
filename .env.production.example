
# Supabase (frontend public config)
# Set your real Supabase credentials in your private .env file (do not commit real secrets)
VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY

VITE_API_URL=YOUR_API_URL
VITE_SITE_URL=YOUR_SITE_URL
# Recommended default: 10000 tokens per period. Adjust for your deployment.
VITE_AI_TOKEN_BUDGET=YOUR_AI_TOKEN_BUDGET
# YouTube Data API v3 (public key; restrict by domain in Google Cloud Console)
VITE_ANDROID_APK_URL=https://cdn.your-domain.com/studyshare-android.apk
# Optional display label for the APK download page
VITE_ANDROID_APP_VERSION=1.0.5 (Build 6)
# Optional backup mirror URL
# VITE_ANDROID_APK_FALLBACK_URL=https://mirror.your-domain.com/studyshare-android.apk

# Firebase (frontend web config)
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef123456
