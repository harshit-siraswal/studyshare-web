# Frontend environment template (safe to commit)
# Copy to .env.local (development) or configure in Vercel project settings.

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# Firebase (frontend SDK config, not admin/service keys)
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef123456

# reCAPTCHA
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# Agora (never expose primary certificates in frontend)
VITE_AGORA_APP_ID=your-agora-app-id

# YouTube Data API v3 (public key; restrict by domain in Google Cloud Console)

# Backend API
VITE_API_URL=https://api.your-domain.com
VITE_SITE_URL=https://your-domain.com
# Never set VITE_API_URL to localhost for production deployments.

# Android APK distribution
# Required in production if your host does not fetch Git LFS files (for example Vercel without LFS enabled).
VITE_ANDROID_APK_URL=https://cdn.your-domain.com/studyshare-android.apk
# Optional backup mirror URL
# VITE_ANDROID_APK_FALLBACK_URL=https://mirror.your-domain.com/studyshare-android.apk

# AI usage UI fallback (frontend display fallback only)
VITE_AI_TOKEN_BUDGET=10000

# Payments (public key only for frontend)
VITE_RAZORPAY_KEY_ID=your-razorpay-key-id

